{
  "name": "server",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "node --env-file-if-exists=.env src/main.ts",
    "dev:docker": "node src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "start": "node --env-file-if-exists=.env dist/src/main.js",
    "build": "tsc && cp src/drizzle/*.sql dist/src/drizzle/ && cp -R src/drizzle/meta dist/src/drizzle/",
    "test": "node --env-file=.env.example --test src/__tests__/**/*.test.ts"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "bloom-filters": "^3.0.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "hono-rate-limiter": "^0.5.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "redis": "^4.6.5",
    "unstorage": "^1.17.3",
    "zod": "^4.2.1"
  }
}
