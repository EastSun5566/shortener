{
  "name": "shortener",
  "version": "2.0.0",
  "description": "🔗 A good URL shortener",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "pnpm --filter server typecheck && pnpm --filter web typecheck",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "knip": "knip --dependencies",
    "test": "pnpm run server:test",
    "test:production": "node --env-file=server/.env.example --test server/dist/src/__production_tests__/*.test.js",
    "test:e2e": "pnpm run web:test:e2e",
    "build": "pnpm run server:build && pnpm run web:build",
    "check": "pnpm typecheck && pnpm lint && pnpm knip && pnpm test && pnpm build && pnpm test:production",
    "server:dev": "pnpm --filter server dev",
    "server:migrate": "pnpm --filter server db:migrate",
    "server:build": "pnpm --filter server build",
    "server:start": "pnpm --filter server start",
    "server:test": "pnpm --filter server test",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:start": "pnpm --filter web preview",
    "web:test:e2e": "pnpm --filter web test:e2e"
  },
  "author": "Michael Wang <hi@eastsun.me>",
  "license": "MIT",
  "devDependencies": {
    "knip": "6.26.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "7.0.2"
  }
}
