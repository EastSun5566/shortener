#!/command/with-contenv sh
set -eu

attempt=1
while [ "$attempt" -le 120 ]; do
  if pg_isready --host=127.0.0.1 --port=5432 --username=shortener --dbname=shortener >/dev/null 2>&1 && \
    redis-cli -h 127.0.0.1 -p 6379 ping 2>/dev/null | grep -qx PONG; then
    break
  fi

  if [ "$attempt" -eq 120 ]; then
    echo "ERROR: PostgreSQL and Redis did not become ready within 120 seconds." >&2
    exit 1
  fi

  attempt=$((attempt + 1))
  sleep 1
done

export DATABASE_URL=postgresql://shortener@127.0.0.1:5432/shortener
export REDIS_URL=redis://127.0.0.1:6379

cd /app
exec s6-setuidgid node node /app/server/dist/src/main.js
